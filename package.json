{
  "name": "workjs",
  "version": "0.1.0",
  "description": "Structured concurrency runtime for TypeScript.",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "author": "Admilson B. F. Cossa",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ai": {
      "import": "./dist/ai/index.js",
      "types": "./dist/ai/index.d.ts"
    },
    "./observability": {
      "import": "./dist/observability/index.js",
      "types": "./dist/observability/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs'); for (const p of ['dist','coverage']) fs.rmSync(p,{recursive:true,force:true});\"",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "check:no-network": "node scripts/check-no-network.mjs",
    "check:size": "npm run build && node scripts/check-bundle-size.mjs",
    "check:benchmark": "npm run build && node scripts/check-benchmark.mjs",
    "check:leak": "npm run build && node --expose-gc scripts/check-leak.mjs",
    "pack:dry": "npm pack --dry-run --json",
    "test": "npm run build && vitest run",
    "test:coverage": "npm run build && vitest run --coverage",
    "verify": "npm run typecheck && npm run check:no-network && npm test && npm run check:size && npm run check:benchmark && npm run check:leak && npm run pack:dry"
  },
  "engines": {
    "node": ">=20.11"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
