{
  "name": "workjs",
  "version": "0.1.0",
  "description": "Structured concurrency runtime for TypeScript.",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "author": "Admilson B. F. Cossa",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs'); for (const p of ['dist','coverage']) fs.rmSync(p,{recursive:true,force:true});\"",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "check:no-network": "node scripts/check-no-network.mjs",
    "pack:dry": "npm pack --dry-run --json",
    "test": "npm run build && node --test tests/unit/*.test.js",
    "verify": "npm run typecheck && npm run check:no-network && npm test && npm run pack:dry"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0"
  }
}
